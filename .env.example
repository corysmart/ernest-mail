# Runtime server config
PORT=3100
# NODE_ENV controls binding host: production binds 0.0.0.0; otherwise 127.0.0.1

# Admin authentication (for /accounts, /agents/register, /credits)
API_KEY=change-me

# Agent routes (/emails/send) use X-Attestation header, not API key.
# Agents must be registered via POST /agents/register first.

# Persistence locations
ACCOUNTS_PATH=./data/accounts.json
AGENTS_PATH=./data/agents.json

# Rate limiting (sliding window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Attestation / WebAuthn options for agent registration
RP_ID=localhost
RP_NAME=ernest-mail
RP_ORIGIN=http://127.0.0.1:3100

# Email providers
# Resend (production default): set RESEND_API_KEY to enable
RESEND_API_KEY=
# Verified sender for Resend (e.g. "Acme <onboarding@resend.dev>" or account email)
RESEND_FROM=
# Local dev provider requires no secrets
